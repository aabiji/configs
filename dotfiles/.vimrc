set hlsearch
set nowrap
set title
set number
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set ignorecase
set smartcase
set termguicolors
set background=dark
set splitbelow
set splitright
set noswapfile
set nobackup
set tabpagemax=100
set viminfofile=NONE
nnoremap <S-l> <S-a>
nnoremap <C-l> :tabnext<CR>
nnoremap <C-h> :tabprev<CR>
